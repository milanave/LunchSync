# Copy to .env and fill in. Source it before running fastlane, or fastlane-dotenv loads it automatically.
# Create the App Store Connect API key here: https://appstoreconnect.apple.com/access/integrations/api
# The key needs at least "App Manager" role to upload to TestFlight and App Store.

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8

# Optional — only needed if you ever run lanes that require Apple ID login (we use API key instead).
FASTLANE_APPLE_ID=you@example.com
# FASTLANE_ITC_TEAM_ID=
